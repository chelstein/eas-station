SECRET_KEY=replace-with-a-long-random-string
FLASK_DEBUG=false
FLASK_ENV=production
DOMAIN_NAME=localhost
SSL_EMAIL=admin@example.com
CERTBOT_STAGING=0
DATABASE_URL=postgresql+psycopg2://eas_station:change-me@127.0.0.1:5432/alerts
POLL_INTERVAL_SEC=120
NOAA_USER_AGENT=EAS Station (+https://github.com/KR8MER/eas-station; support@easstation.com)
IPAWS_CAP_FEED_URLS=
LOCATION_CONFIG='{"timezone": "America/New_York", "county_name": "Your County", "state_code": "OH", "zone_codes": "", "fips_codes": "", "storage_zone_codes": "", "map_center_lat": 40.0, "map_center_lng": -83.0, "map_zoom": 9}'
EAS_BROADCAST_ENABLED=true
EAS_ORIGINATOR=WXR
EAS_STATION_ID=STATION
EAS_OUTPUT_DIR=static/eas_messages
EAS_TTS_PROVIDER=pyttsx3
AZURE_OPENAI_CONFIG='{"endpoint": "https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT/audio/speech?api-version=2025-03-01-preview", "key": "", "model": "tts-1", "voice": "alloy", "speed": 1.0}'
OLED_ENABLED=true
LOG_LEVEL=INFO
LOG_FILE=logs/eas_station.log
WEB_ACCESS_LOG=false
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300
CACHE_REDIS_URL=redis://localhost:6379/0
MAX_WORKERS=2
EAS_SCAN_INTERVAL=3.0
MAX_CONCURRENT_EAS_SCANS=2
BACKUP_DIR=/var/backups/eas-station
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
ICECAST_ENABLED=true
ICECAST_INTERNAL_URL=http://localhost:8000
ICECAST_PUBLIC_URL=
ICECAST_CONFIG='{"source_password": "change-me", "relay_password": "change-me", "admin_user": "admin", "admin_password": "change-me", "admin_email": "admin@example.com"}'
TZ=America/New_York

# ============================================================================
# GPIO Configuration
# ============================================================================
# Master enable/disable for GPIO control
GPIO_ENABLED=false

# GPIO Pin Map - Configure all GPIO pins in one place
# Format: JSON object mapping pin numbers (BCM) to configuration
#
# Available pins (BCM numbering): 5-27 (pins 2,3,4,14 are reserved when OLED is enabled)
#
# Configuration options for each pin:
#   - name: Descriptive name (e.g., "EAS Transmitter PTT")
#   - active_high: true for active-high, false for active-low (default: true)
#   - hold_seconds: Minimum time to hold pin active (default: 5.0)
#   - watchdog_seconds: Maximum time before auto-deactivate (default: 300.0)
#
# Example:
# GPIO_PIN_MAP={"17": {"name": "EAS Transmitter PTT", "active_high": true, "hold_seconds": 5.0, "watchdog_seconds": 300.0}, "27": {"name": "Backup Relay", "active_high": true}}
GPIO_PIN_MAP=

# GPIO behavior matrix for automated control (optional)
# Maps pins to automated behaviors during alert processing
# Available behaviors: duration_of_alert, playout, flash, five_seconds, incoming_alert, forwarding_alert
# Example: GPIO_BEHAVIOR_MATRIX={"17": ["duration_of_alert"], "27": ["flash"]}
GPIO_BEHAVIOR_MATRIX=

# ============================================================================
# OLED Display Configuration
# ============================================================================
# Enable the Argon Industria SSD1306 OLED module (128x64)
# IMPORTANT: When enabled, GPIO pins 2, 3, 4, and 14 are reserved for OLED use:
#   - Pin 2 (BCM) / Physical 3: I2C SDA1
#   - Pin 3 (BCM) / Physical 5: I2C SCL1
#   - Pin 4 (BCM) / Physical 7: Front-panel button
#   - Pin 14 (BCM) / Physical 8: Display heartbeat
OLED_ENABLED=false
OLED_I2C_BUS=1
OLED_I2C_ADDRESS=0x3C
# Screen rotation settings
SCREENS_AUTO_START=true

# LED Sign Configuration
# BetaBrite/Alpha LED sign support
LED_SIGN_ENABLED=false
LED_PORT=/dev/ttyUSB1
LED_BAUDRATE=9600
LED_SERIAL_MODE=RS232
LED_DEFAULT_TEXT=PUTNAM COUNTY,EMERGENCY MGMT,NO ALERTS,SYSTEM READY

# VFD Display Configuration
# Noritake GU140x32F-7000B VFD display settings
# Supports both direct serial and network (TCP) connections via Waveshare RS232/485 WiFi adapter
VFD_PORT=/dev/ttyUSB0
VFD_BAUDRATE=38400
# For network connection via Waveshare adapter, use: socket://192.168.8.122:10001
# Leave VFD_PORT empty to disable VFD display
