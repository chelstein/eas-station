.env
.env.*
!.env.example
!stack.env
__pycache__/
*.pyc
*.pyo
*.pyd
.DS_Store
.idea/

# Runtime-generated secret key (auto-created when SECRET_KEY is absent from .env)
.secret_key
.secret_key.tmp

# VSCode local settings (may contain secrets)
.vscode/settings.local.json
.vscode/sqltools.settings.json

logs/
*.log
static/eas_messages/
*.sqlite3

# Certbot certificates and data (contains private keys)
certbot_data/

# Docker Compose override files (site-specific)
docker-compose.override.yml

# Development data
dev_data/

# MkDocs documentation build
site/
.cache/

# Pytest
.pytest_cache/
tests/logs/*.log
tests/test_data/*
!tests/test_data/README.md
!tests/logs/README.md
htmlcov/
.coverage

# Bare metal ISO build artifacts
/tmp/eas-station-iso-build/
bare-metal/scripts/*.iso
*.iso

# Development-only directories (not for ISO)
bugs/
tests/bug_reproductions/

# Don't allow root clutter - keep docs in proper directories
/*_FIX*.md
/*_DIAGNOSTIC*.md
/*_DEPLOYMENT*.md
/*_APPLIED*.md
/*_REMOVAL*.md
/*_AUDIT*.md
/*_SUMMARY*.md
/APPLY_*.md
/DEPLOY_*.sh
/FIX_*.md
/FIXES_*.md

