# Postal configuration template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to postal/postal.yml — DO NOT commit postal.yml (it contains secrets).
# setup_postal.sh fills in the placeholder values automatically.
# ─────────────────────────────────────────────────────────────────────────────

# Web interface
web:
  host: localhost
  protocol: http

# Main database (MariaDB running in Docker)
database:
  host: postal-mariadb
  username: postal
  password: POSTAL_DB_PASSWORD_PLACEHOLDER
  database: postal

# Per-message database prefix (tables: postal_1, postal_2 …)
message_db:
  prefix: postal

# RabbitMQ message broker
rabbitmq:
  host: postal-rabbitmq
  username: postal
  password: POSTAL_RABBITMQ_PASSWORD_PLACEHOLDER
  vhost: postal

# SMTP listener (port 25 inside container → 2525 on the host)
smtp_server:
  port: 25
  tls_enabled: false
  log_connect: true
  strip_received_headers: false

# Rails secret key (must be long random string — generated by setup_postal.sh)
rails_secret_key: RAILS_SECRET_KEY_PLACEHOLDER

# Send all logs to stdout so Docker captures them
logging:
  stdout: true
