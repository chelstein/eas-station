set -e

# Color definitions
BLUE_BG="\e[44m"
GRAY_BG="\e[100m"
BOLD="\e[1m"
NC="\e[0m"

# Configuration paths
INSTALL_DIR="/opt/eas-station"
CONFIG_FILE="${INSTALL_DIR}/.env"
SERVICE_USER="eas-station"

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    echo "This script must be run as root (use sudo)"
    echo "Please run: sudo eas-config"
    exit 1
fi

# Check if whiptail is available
if ! command -v whiptail &> /dev/null; then
    echo "Error: whiptail is required but not installed."
    echo "Install it with: apt-get install whiptail"
    exit 1
fi

# Add branding footer for whiptail dialogs
whiptail_footer() {
    echo "Copyright (c) 2025 Timothy Kramer (KR8MER) | AGPL v3 / Commercial License"
}

# Helper function to read current config value
get_config_value() {
    local key="$1"
    local default="$2"
    if [ -f "$CONFIG_FILE" ]; then
        # Get value and remove quotes if present
        local value=$(grep "^${key}=" "$CONFIG_FILE" 2>/dev/null | cut -d'=' -f2-)
        # Remove leading/trailing quotes (both single and double)
        value=$(echo "$value" | sed 's/^["'\'']//' | sed 's/["'\'']$//')
        if [ -n "$value" ]; then
            echo "$value"
        else
            echo "$default"
        fi
    else
        echo "$default"
    fi
}

# Helper function to set config value
set_config_value() {
    local key="$1"
    local value="$2"
    
    if [ -f "$CONFIG_FILE" ]; then
        # Create a temporary file for safer editing
        local temp_file=$(mktemp)
        
        # Check if key exists
        if grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
            # Update existing key - use awk for safer replacement
            awk -v key="$key" -v val="$value" '
                BEGIN { FS=OFS="=" }
                $1 == key { $2=val; found=1 }
                { print }
            ' "$CONFIG_FILE" > "$temp_file"
            mv "$temp_file" "$CONFIG_FILE"
        else
            # Add new key
            echo "${key}=${value}" >> "$CONFIG_FILE"
        fi
    else
        echo "Error: Configuration file not found at $CONFIG_FILE"
        return 1
    fi
}

# Helper to restart services
restart_services() {
    if whiptail --title "Restart Services" --yesno "Would you like to restart EAS Station services to apply changes?" 10 60; then
        systemctl restart eas-station.target 2>/dev/null || true
        whiptail --title "Services Restarted" --msgbox "EAS Station services have been restarted." 8 60
    fi
}

# Main menu
show_main_menu() {
    while true; do
        CHOICE=$(whiptail --title "EAS Station Configuration Tool" --menu "\nConfigure your EAS Station (similar to raspi-config)\n\nSelect an option:" 20 78 10 \
            "1" "System Settings (Hostname, Location, Callsign)" \
            "2" "Database Configuration (PostgreSQL settings)" \
            "3" "Alert Sources (NOAA, IPAWS, Manual)" \
            "4" "Audio Settings (Receivers, Icecast, Broadcasts)" \
            "5" "Hardware Integration (GPIO, LED Signs, VFD)" \
            "6" "Network Settings (Firewall, Remote Access)" \
            "7" "Advanced Options (Logging, Performance)" \
            "8" "View Current Configuration" \
            "9" "Restart Services" \
            "0" "Exit" \
            3>&1 1>&2 2>&3)
        
        exitstatus=$?
        if [ $exitstatus != 0 ]; then
            return
        fi
        
        case "$CHOICE" in
            1) system_settings_menu ;;
            2) database_config_menu ;;
            3) alert_sources_menu ;;
            4) audio_settings_menu ;;
            5) hardware_integration_menu ;;
            6) network_settings_menu ;;
            7) advanced_options_menu ;;
            8) view_configuration ;;
            9) restart_services ;;
            0) return ;;
        esac
    done
}

# System Settings Menu
system_settings_menu() {
    while true; do
        CURRENT_HOSTNAME=$(get_config_value "HOSTNAME" "eas-station")
        CURRENT_CALLSIGN=$(get_config_value "EAS_CALLSIGN" "UNKNOWN")
        CURRENT_LOCATION=$(get_config_value "EAS_LOCATION" "Unknown Location")
        CURRENT_FIPS=$(get_config_value "FIPS_CODES" "Not configured")
        
        CHOICE=$(whiptail --title "System Settings" --backtitle "$(whiptail_footer)" --menu "\nCurrent Settings:\nHostname: $CURRENT_HOSTNAME\nCallsign: $CURRENT_CALLSIGN\nLocation: $CURRENT_LOCATION\nFIPS Codes: $CURRENT_FIPS\n\nSelect option to configure:" 20 78 7 \
            "1" "Change Hostname" \
            "2" "Set EAS Callsign/Identifier" \
            "3" "Set Station Location" \
            "4" "Set County/Region" \
            "5" "Configure FIPS Codes" \
            "6" "Back to Main Menu" \
            3>&1 1>&2 2>&3)
        
        exitstatus=$?
        if [ $exitstatus != 0 ] || [ "$CHOICE" = "6" ]; then
            return
        fi
        
        case "$CHOICE" in
            1)
                NEW_VALUE=$(whiptail --inputbox "Enter new hostname:" 10 60 "$CURRENT_HOSTNAME" 3>&1 1>&2 2>&3)
                if [ $? = 0 ] && [ -n "$NEW_VALUE" ]; then
                    set_config_value "HOSTNAME" "$NEW_VALUE"
                    hostnamectl set-hostname "$NEW_VALUE" 2>/dev/null || true
                    whiptail --msgbox "Hostname updated to: $NEW_VALUE" 8 60
                fi
                ;;
            2)
                NEW_VALUE=$(whiptail --inputbox "Enter EAS station callsign/identifier:" 10 60 "$CURRENT_CALLSIGN" 3>&1 1>&2 2>&3)
                if [ $? = 0 ] && [ -n "$NEW_VALUE" ]; then
                    set_config_value "EAS_CALLSIGN" "$NEW_VALUE"
                    whiptail --msgbox "EAS Callsign updated to: $NEW_VALUE" 8 60
                fi
