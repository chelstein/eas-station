                fi
                set_config_value "DEBUG" "$NEW_VALUE"
                whiptail --msgbox "Debug mode: $NEW_VALUE\n\nYou may need to restart services." 10 60
                ;;
            3)
                whiptail --msgbox "Performance tuning options are available in .env file:\n\n- WORKER_PROCESSES\n- MAX_CONNECTIONS\n- CACHE_SIZE\n- POOL_SIZE\n\nEdit $CONFIG_FILE for advanced settings." 14 70
                ;;
            4)
                if [ -d "/var/log/eas-station" ]; then
                    LOG_FILES=$(ls -lt /var/log/eas-station/*.log 2>/dev/null | head -5 | awk '{print $9}' || echo "No log files found")
                    whiptail --title "Recent Log Files" --msgbox "Recent logs:\n\n$LOG_FILES\n\nView with: tail -f /var/log/eas-station/app.log" 16 70
                else
                    whiptail --msgbox "Log directory not found at /var/log/eas-station" 8 60
                fi
                ;;
        esac
    done
}

# View Configuration
view_configuration() {
    if [ -f "$CONFIG_FILE" ]; then
        # Show key configuration values (hide sensitive data)
        CONFIG_SUMMARY=$(grep -v "PASSWORD\|SECRET\|KEY" "$CONFIG_FILE" 2>/dev/null | grep "=" | head -20 || echo "No configuration found")
        whiptail --title "Current Configuration" --msgbox "Configuration file: $CONFIG_FILE\n\nKey settings (sensitive values hidden):\n\n$CONFIG_SUMMARY\n\nEdit manually with:\nsudo nano $CONFIG_FILE" 24 78
    else
        whiptail --msgbox "Configuration file not found at: $CONFIG_FILE" 8 60
    fi
}

