# EAS Station sudoers configuration
# This file should be installed to: /etc/sudoers.d/eas-station
# Install with: sudo cp config/sudoers-eas-station /etc/sudoers.d/eas-station && sudo chmod 440 /etc/sudoers.d/eas-station
#
# Allows the eas-station user to run specific commands without password
# Required for the web UI to manage SSL certificates and system services
# Also allows root to run commands as eas-station without password (for update.sh)

# Allow root to run any command as eas-station user without password
# This is required for update.sh which runs as root and needs to execute
# git, pip, python, and alembic commands as the eas-station user
root ALL=(eas-station) NOPASSWD: ALL

# Certbot certificate management
# Allow all certbot commands since it's a trusted system tool that requires root
eas-station ALL=(ALL) NOPASSWD: /usr/bin/certbot

# Certbot data directory management
# These commands are needed to fix permissions on root-owned files created by certbot
# Using broader patterns since sudoers globbing is limited
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /opt/eas-station/certbot_data/config
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /opt/eas-station/certbot_data/work
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /opt/eas-station/certbot_data/logs
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chmod -R 777 /opt/eas-station/certbot_data
eas-station ALL=(ALL) NOPASSWD: /usr/bin/find /opt/eas-station/certbot_data -name .certbot.lock -delete
eas-station ALL=(ALL) NOPASSWD: /usr/bin/cat /opt/eas-station/certbot_data/logs/letsencrypt.log

# Webroot directory management (required for certbot webroot method)
# Certbot runs as root and needs to write challenge files to /var/www/certbot
# Nginx (www-data) needs to read these files to serve them to Let's Encrypt
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /var/www/certbot/.well-known/acme-challenge
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chown -R root\:root /var/www/certbot
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chmod -R 755 /var/www/certbot

# Nginx log directory management (DEPRECATED - not actively used)
# Certbot's nginx plugin has fundamental permission issues that cannot be reliably solved.
# We recommend using standalone or webroot modes instead of the nginx plugin.
# These sudoers entries are kept for backward compatibility and troubleshooting,
# but the nginx plugin is no longer the recommended method due to permission issues
# with nginx -t running in different security contexts (AppArmor, SELinux, etc.)
# PLANNED REMOVAL: Consider removing these entries in version 3.0.0 or later
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /var/log/nginx
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chmod 755 /var/log/nginx
eas-station ALL=(ALL) NOPASSWD: /usr/bin/touch /var/log/nginx/error.log
eas-station ALL=(ALL) NOPASSWD: /usr/bin/touch /var/log/nginx/access.log
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chown www-data\:adm /var/log/nginx/error.log
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chown www-data\:adm /var/log/nginx/access.log
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chmod 666 /var/log/nginx/error.log
eas-station ALL=(ALL) NOPASSWD: /usr/bin/chmod 666 /var/log/nginx/access.log

# Certificate installation (required for installing certificates after obtaining them)
# These commands are used by _install_certificate_internal() in webapp/admin/certbot.py
# Note: Domain names are validated in Python before being passed to these commands
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /etc/letsencrypt
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /etc/letsencrypt/live
eas-station ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /etc/nginx/snippets
eas-station ALL=(ALL) NOPASSWD: /usr/bin/rm -rf /etc/letsencrypt/live/*
eas-station ALL=(ALL) NOPASSWD: /usr/bin/ln -s * /etc/letsencrypt/live/*
eas-station ALL=(ALL) NOPASSWD: /usr/bin/tee /etc/nginx/snippets/ssl-letsencrypt.conf
eas-station ALL=(ALL) NOPASSWD: /usr/bin/sed -i * /etc/nginx/sites-available/eas-station
eas-station ALL=(ALL) NOPASSWD: /usr/bin/grep -q * /etc/nginx/sites-available/eas-station
eas-station ALL=(ALL) NOPASSWD: /usr/sbin/nginx -t
eas-station ALL=(ALL) NOPASSWD: /usr/sbin/nginx

# Nginx service management (required for standalone certbot mode)
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop nginx
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl start nginx
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart nginx
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl reload nginx
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl is-active nginx
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl status nginx

# Certbot timer management (for automatic renewal)
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl enable certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl disable certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl start certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl stop certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl is-enabled certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl is-active certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl status certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl enable --now certbot.timer
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl disable --now certbot.timer

# Icecast configuration management (required for password regeneration from web UI)
eas-station ALL=(ALL) NOPASSWD: /usr/bin/sed -i * /etc/icecast2/icecast.xml
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart icecast2
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart icecast
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl status icecast2
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl status icecast

# Audio service management (required to reload Icecast credentials after password change)
eas-station ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart eas-station-audio
